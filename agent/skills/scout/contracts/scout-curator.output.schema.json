{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "scout-curator output",
  "type": "object",
  "required": ["kind", "timestamp", "suggested_terms"],
  "additionalProperties": false,
  "properties": {
    "kind": {"type": "string", "const": "scout_curator"},
    "timestamp": {"type": "string"},
    "suggested_terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "frequency", "confidence"],
        "additionalProperties": false,
        "properties": {
          "term": {"type": "string"},
          "frequency": {"type": "integer", "minimum": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "recommended_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "active_skills", "confidence"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "active_skills": {"type": "integer", "minimum": 0},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
