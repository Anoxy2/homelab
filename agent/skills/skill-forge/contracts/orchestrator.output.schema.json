{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["kind", "timestamp", "live", "vet_score", "summary"],
  "properties": {
    "kind": {"const": "orchestrate_run"},
    "timestamp": {"type": "string"},
    "live": {"type": "boolean"},
    "vet_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "summary": {
      "type": "object",
      "required": ["promoted", "blocked", "conflicts"],
      "properties": {
        "promoted": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "conflicts": {"type": "integer", "minimum": 0}
      }
    }
  }
}
