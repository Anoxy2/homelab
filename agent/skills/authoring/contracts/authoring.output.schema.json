{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "authoring job output",
  "description": "Output when a new skill is queued for authoring. job_id is printed on stdout.",
  "type": "object",
  "required": ["job_id", "slug", "status"],
  "additionalProperties": true,
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["queued", "drafted", "rejected"] },
    "created_at": { "type": "string" },
    "authoring_mode": { "type": "string" },
    "authoring_quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "authoring_quality_tier": { "type": "string" }
  }
}
